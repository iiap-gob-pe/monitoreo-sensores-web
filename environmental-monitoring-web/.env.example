# ============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO - FRONTEND
# ============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Configura la URL de tu API según tu entorno
# 3. Reinicia el servidor de desarrollo después de cambios
# ============================================================================

# ----------------------------------------------------------------------------
# CONFIGURACIÓN DE LA API BACKEND
# ----------------------------------------------------------------------------

# Para desarrollo local:
VITE_API_URL=http://localhost:3000/api

# Para producción:
# VITE_API_URL=https://tu-dominio.com/api

# ----------------------------------------------------------------------------
# INFORMACIÓN DE LA APLICACIÓN
# ----------------------------------------------------------------------------
VITE_APP_NAME=IIAP Monitoreo Ambiental
VITE_APP_VERSION=1.0.0

# ----------------------------------------------------------------------------
# ENTORNO
# ----------------------------------------------------------------------------
VITE_NODE_ENV=development

# ============================================================================
# NOTAS
# ============================================================================
# - Todas las variables deben comenzar con VITE_
# - Reinicia el servidor después de cambiar variables
# - En producción, configura en el panel de tu hosting
# ============================================================================
