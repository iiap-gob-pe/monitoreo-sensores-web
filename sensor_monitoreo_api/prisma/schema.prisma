generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// SITIOS - Lugares fijos donde se instalan sensores estacionarios
// ============================================================================
model sitios {
  id_sitio              Int       @id @default(autoincrement())
  nombre                String    @db.VarChar(100)
  descripcion           String?
  referencia_ubicacion  String?   @db.VarChar(255)   // Referencia textual (ej: "Frente al parque central")
  latitud               Decimal?  @db.Decimal(10, 8)
  longitud              Decimal?  @db.Decimal(11, 8)
  altitud               Decimal?  @db.Decimal(8, 2)
  zona                  String    @db.VarChar(50)     // Urbana, Rural, Bosque, Rio
  estado                String?   @default("activo") @db.VarChar(20)
  created_at            DateTime? @default(now()) @db.Timestamp(6)

  sensores              sensores[]

  @@map("sitios")
}

// ============================================================================
// CAMPANAS DE MONITOREO - Campañas de campo con sensores móviles
// ============================================================================
model campanas_monitoreo {
  id_campana    Int       @id @default(autoincrement())
  nombre        String    @db.VarChar(100)
  descripcion   String?
  zona          String    @db.VarChar(50)
  fecha_inicio  DateTime  @db.Date
  fecha_fin     DateTime? @db.Date
  estado        String?   @default("planificada") @db.VarChar(20)  // planificada, activa, finalizada
  created_by    Int?
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  usuario_creador usuarios?        @relation(fields: [created_by], references: [id_usuario], onDelete: SetNull, onUpdate: NoAction)
  campana_sensor  campana_sensor[]

  @@map("campanas_monitoreo")
}

// ============================================================================
// CAMPANA_SENSOR - Relacion N:N entre campañas y sensores móviles
// ============================================================================
model campana_sensor {
  id          Int      @id @default(autoincrement())
  id_campana  Int
  id_sensor   String   @db.VarChar(50)
  asignado_at DateTime @default(now()) @db.Timestamp(6)

  campana campanas_monitoreo @relation(fields: [id_campana], references: [id_campana], onDelete: Cascade, onUpdate: NoAction)
  sensor  sensores           @relation(fields: [id_sensor], references: [id_sensor], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id_campana, id_sensor])
  @@map("campana_sensor")
}

// ============================================================================
// SENSORES - Dispositivos IoT (estacionarios o móviles)
// ============================================================================
model sensores {
  id_sensor            String                   @id @db.VarChar(50)
  nombre_sensor        String                   @db.VarChar(100)
  is_movil             Boolean?                 @default(false)
  description          String?
  // Estacionarios: ubicación fija vinculada a un sitio
  id_sitio             Int?
  // Móviles: ubicación GPS del dispositivo (se actualiza con cada lectura)
  latitud              Decimal?                 @db.Decimal(10, 8)
  longitud             Decimal?                 @db.Decimal(11, 8)
  altitud              Decimal?                 @db.Decimal(8, 2)
  zona                 String?                  @db.VarChar(50)
  installation_date    DateTime?                @default(dbgenerated("CURRENT_DATE")) @db.Date
  created_at           DateTime?                @default(now()) @db.Timestamp(6)
  last_seen            DateTime?                @db.Timestamp(6)
  estado               String?                  @default("Activo") @db.VarChar(20)

  sitio                sitios?                  @relation(fields: [id_sitio], references: [id_sitio], onDelete: SetNull, onUpdate: NoAction)
  alertas              alertas[]
  lecturas             lecturas[]
  sensor_umbral        sensor_umbral[]
  recorridos_guardados recorridos_guardados[]
  api_keys             api_keys[]
  campana_sensor       campana_sensor[]

  @@map("sensores")
}

// ============================================================================
// LECTURAS - Datos ambientales capturados por sensores
// ============================================================================
model lecturas {
  id_lectura       Int       @id @default(autoincrement())
  id_sensor        String?   @db.VarChar(50)
  lectura_datetime DateTime  @db.Timestamp(6)
  temperatura      Decimal?  @db.Decimal(5, 2)
  humedad          Decimal?  @db.Decimal(5, 2)
  co2_nivel        Int?
  co_nivel         Decimal?  @db.Decimal(6, 2)
  latitud          Decimal?  @db.Decimal(10, 8)
  longitud         Decimal?  @db.Decimal(11, 8)
  altitud          Decimal?  @db.Decimal(8, 2)
  zona             String?   @db.VarChar(20)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  sensor           sensores? @relation(fields: [id_sensor], references: [id_sensor], onDelete: Cascade, onUpdate: NoAction)

  @@index([lectura_datetime(sort: Desc)], map: "idx_lecturas_lectura_datetime")
  @@index([id_sensor, lectura_datetime(sort: Desc)], map: "idx_lecturas_sensor_lectura_datetime")
  @@map("lecturas")
}

// ============================================================================
// ALERTAS
// ============================================================================
model alertas {
  id_alerta        Int       @id @default(autoincrement())
  id_sensor        String?   @db.VarChar(50)
  alerta_tipo      String    @db.VarChar(50)
  parametro_nombre String?   @db.VarChar(30)
  umbral_valor     Decimal?  @db.Decimal(10, 2)
  actual_valor     Decimal?  @db.Decimal(10, 2)
  mensaje          String
  gravedad         String?   @default("Medio") @db.VarChar(20)
  se_activo_at     DateTime? @default(now()) @db.Timestamp(6)
  resuelto_at      DateTime? @db.Timestamp(6)
  is_resolved      Boolean?  @default(false)
  sensor           sensores? @relation(fields: [id_sensor], references: [id_sensor], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_sensor, se_activo_at(sort: Desc)], map: "idx_alertas_sensor_se_activo_at")
  @@map("alertas")
}

// ============================================================================
// SENSOR_UMBRAL - Umbrales de alerta por sensor y parámetro
// ============================================================================
model sensor_umbral {
  id_sensor_umbral Int       @id @default(autoincrement())
  id_sensor        String?   @db.VarChar(50)
  parametro_nombre String    @db.VarChar(30)
  min_umbral       Decimal?  @db.Decimal(10, 2)
  max_umbral       Decimal?  @db.Decimal(10, 2)
  alerta_habilitar Boolean?  @default(true)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  sensor           sensores? @relation(fields: [id_sensor], references: [id_sensor], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id_sensor, parametro_nombre])
  @@map("sensor_umbral")
}

// ============================================================================
// USUARIOS
// ============================================================================
model usuarios {
  id_usuario           Int                    @id @default(autoincrement())
  username             String                 @unique @db.VarChar(50)
  email                String                 @unique @db.VarChar(100)
  password_hash        String                 @db.VarChar(255)
  nombre_completo      String                 @db.VarChar(100)
  rol                  String                 @db.VarChar(20)
  estado               String?                @default("activo") @db.VarChar(20)
  ultimo_acceso        DateTime?              @db.Timestamp(6)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @updatedAt @db.Timestamp(6)
  logs_actividad       logs_actividad[]
  preferencias_sistema preferencias_sistema?
  api_keys_creadas     api_keys[]
  campanas_creadas     campanas_monitoreo[]

  @@index([email], map: "idx_usuarios_email")
  @@index([username], map: "idx_usuarios_username")
}

// ============================================================================
// LOGS_ACTIVIDAD
// ============================================================================
model logs_actividad {
  id_log         Int       @id @default(autoincrement())
  id_usuario     Int?
  username       String?   @db.VarChar(50)
  accion         String    @db.VarChar(100)
  tabla_afectada String?   @db.VarChar(50)
  id_registro    String?   @db.VarChar(100)
  detalles       String?
  ip_address     String?   @db.VarChar(50)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  usuario        usuarios? @relation(fields: [id_usuario], references: [id_usuario], onUpdate: NoAction)

  @@index([created_at], map: "idx_logs_fecha")
  @@index([id_usuario], map: "idx_logs_usuario")
}

// ============================================================================
// RECORRIDOS_GUARDADOS
// ============================================================================
model recorridos_guardados {
  id_recorrido     Int       @id @default(autoincrement())
  id_sensor        String    @db.VarChar(50)
  nombre_recorrido String    @db.VarChar(100)
  fecha_recorrido  DateTime  @db.Date
  hora_inicio      DateTime  @db.Timestamp(6)
  hora_fin         DateTime  @db.Timestamp(6)
  total_puntos     Int
  distancia_km     Decimal?  @db.Decimal(10, 2)
  duracion_minutos Int?
  puntos_geojson   Json
  metadata         Json?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  usuario_creo     String?   @db.VarChar(50)
  sensor           sensores  @relation(fields: [id_sensor], references: [id_sensor], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_sensor, fecha_recorrido], map: "idx_recorridos_sensor_fecha")
  @@map("recorridos_guardados")
}

// ============================================================================
// PREFERENCIAS_SISTEMA
// ============================================================================
model preferencias_sistema {
  id_preferencia           Int       @id @default(autoincrement())
  id_usuario               Int       @unique
  zona_horaria             String?   @default("America/Lima") @db.VarChar(50)
  formato_fecha            String?   @default("DD/MM/YYYY") @db.VarChar(20)
  intervalo_actualizacion  Int?      @default(30)
  registros_por_pagina     Int?      @default(20)
  mostrar_graficos         Boolean?  @default(true)
  animaciones_graficos     Boolean?  @default(true)
  created_at               DateTime? @default(now()) @db.Timestamp(6)
  updated_at               DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  usuario                  usuarios  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction)

  @@map("preferencias_sistema")
}

// ============================================================================
// API_KEYS - Claves de autenticación por sensor
// ============================================================================
model api_keys {
  id_api_key       Int       @id @default(autoincrement())
  key_name         String    @db.VarChar(100)
  api_key          String    @unique @db.VarChar(64)
  id_sensor        String?   @db.VarChar(50)
  descripcion      String?
  esta_activo      Boolean   @default(true)
  ultima_uso       DateTime? @db.Timestamp(6)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
  created_by       Int?
  expires_at       DateTime? @db.Timestamp(6)
  usuario_creador  usuarios? @relation(fields: [created_by], references: [id_usuario], onDelete: SetNull, onUpdate: NoAction)
  sensor           sensores? @relation(fields: [id_sensor], references: [id_sensor], onDelete: Cascade, onUpdate: NoAction)

  @@index([api_key], map: "idx_api_keys_key")
  @@index([esta_activo], map: "idx_api_keys_activo")
  @@index([created_by], map: "idx_api_keys_created_by")
  @@index([id_sensor], map: "idx_api_keys_id_sensor")
  @@map("api_keys")
}
