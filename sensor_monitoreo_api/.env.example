# ============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================================
# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Configura los valores según tu entorno (desarrollo/producción)
# 3. NUNCA subas el archivo .env a Git (está en .gitignore)
# ============================================================================

# ----------------------------------------------------------------------------
# ENTORNO Y PUERTO
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ----------------------------------------------------------------------------
# BASE DE DATOS POSTGRESQL
# ----------------------------------------------------------------------------
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd

# Para desarrollo local:
DATABASE_URL="postgresql://postgres:tu_contraseña@localhost:5432/sensores_bd"

# Para producción:
# DATABASE_URL="postgresql://usuario_prod:password_seguro@ip_servidor:5432/sensores_bd"

# ----------------------------------------------------------------------------
# CORS - PERMITIR CONEXIONES DESDE EL FRONTEND
# ----------------------------------------------------------------------------

# Para desarrollo local:
CORS_ORIGIN=http://localhost:5173

# Para producción:
# CORS_ORIGIN=https://tu-dominio.com

# ----------------------------------------------------------------------------
# AUTENTICACIÓN JWT
# ----------------------------------------------------------------------------
# ⚠️ IMPORTANTE: Genera un secret seguro con este comando:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=genera_un_secret_seguro_con_el_comando_de_arriba
JWT_EXPIRES_IN=24h

# ----------------------------------------------------------------------------
# CLAVE PÚBLICA PARA EL FRONTEND
# ----------------------------------------------------------------------------
# Clave estática que el frontend envía en el header X-Public-Key para
# acceder a endpoints de lectura (sensores, lecturas, alertas, etc.)
# sin necesidad de JWT. Genera una con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FRONTEND_PUBLIC_KEY=genera_una_clave_con_el_comando_de_arriba

# ----------------------------------------------------------------------------
# CONFIGURACIÓN DE ALERTAS
# ----------------------------------------------------------------------------
ALERT_CHECK_INTERVAL=60000

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
# development: info o debug
# production: warn o error
LOG_LEVEL=info

# ============================================================================
# ⚠️ NOTAS IMPORTANTES DE SEGURIDAD
# ============================================================================
# 1. NUNCA commitear el archivo .env al repositorio
# 2. Verificar que .env está en .gitignore
# 3. En producción, usar variables de entorno del servidor
# 4. Generar un JWT_SECRET diferente para producción
# 5. Usar contraseñas fuertes para la base de datos
# 6. Cambiar NODE_ENV=production en servidor de producción
# ============================================================================
