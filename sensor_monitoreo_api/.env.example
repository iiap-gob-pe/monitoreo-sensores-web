# Variables de entorno - Ejemplo de configuración
# Copiar este archivo a .env y configurar con valores reales

# Configuración del servidor
PORT=3000
NODE_ENV=development

# Configuración de la base de datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL="postgresql://postgres:tu_contraseña@localhost:5432/sensores_bd"

# Configuración de CORS (permitir conexiones desde el frontend)
CORS_ORIGIN=http://localhost:5173

# Configuración de autenticación JWT
# IMPORTANTE: Generar un secret criptográficamente seguro para producción
# Ejecuta este comando para generar uno nuevo:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_super_seguro_aqui_generalo_con_el_comando_de_arriba
JWT_EXPIRES_IN=24h

# Configuración de alertas
# Intervalo en millisegundos para revisar alertas (60 segundos)
ALERT_CHECK_INTERVAL=60000

# Configuración de logging
LOG_LEVEL=info

# ⚠️ NOTAS IMPORTANTES DE SEGURIDAD:
# 1. NUNCA commitear el archivo .env al repositorio
# 2. Verificar que .env está en .gitignore
# 3. En producción, usar variables de entorno del servidor (no archivo .env)
# 4. Cambiar JWT_SECRET antes de desplegar a producción
# 5. Usar contraseñas fuertes para la base de datos
# 6. El JWT_SECRET de ejemplo arriba es solo para desarrollo